<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/tvSmsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SMS Notifications"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#0D62D0"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvSmsInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable SMS alerts to get notified about upcoming events."
        android:textSize="16sp"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:textColor="#444444" />

    <Button
        android:id="@+id/btnEnableSms"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Enable SMS"
        android:textColor="#FFFFFF"
        android:background="#0C61CE" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Back to Events"
        android:textColor="#0C61CE"
        android:background="#E0E0E0"
        android:layout_marginTop="12dp" />

</LinearLayout>